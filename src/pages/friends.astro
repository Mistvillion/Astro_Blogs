---
import MainGridLayout from '../layouts/MainGridLayout.astro'
import { i18n } from '../i18n/translation'
import { I18nKey } from '../i18n/i18nKey'

const friends = [
  {
    name: "Jaison's ink",
    introduction: "Stay Hungry. Stay Foolish.",
    link: "https://jaison.ink/",
    avatar: "https://jaison.ink/_image?href=%2F_astro%2Favatar.CTKQfaKx.png&w=1280&h=1280&f=webp"
  }
]
---

<MainGridLayout title={i18n(I18nKey.friends)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                {friends.map((friend) => (
                    <a href={friend.link} target="_blank" rel="noopener noreferrer" 
                       class="flex items-center p-4 rounded-xl transition-all bg-transparent hover:bg-[var(--btn-plain-bg-hover)] active:scale-95">
                        <img src={friend.avatar} alt={friend.name} 
                             class="w-16 h-16 rounded-full border-2 border-[var(--primary)] shadow-md mr-4 shrink-0" />
                        <div class="overflow-hidden">
                            <div class="font-bold text-lg text-90 transition-all group-hover:text-[var(--primary)]">
                                {friend.name}
                            </div>
                            <div class="text-sm text-50 line-clamp-1 italic">
                                {friend.introduction}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </div>
</MainGridLayout>